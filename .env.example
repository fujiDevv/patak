# Database Connection Details
# For local SQLite: file:local.db
# For production Turso: libsql://your-db-name-username.turso.io
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# API Webhook Security Secret
# A long random secret string to secure the /api/ingest and /api/recalculate-metrics endpoints
INGEST_SECRET=your_ingest_secret_here
